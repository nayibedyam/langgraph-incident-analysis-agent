          { "name": "LC",     "applies_to_architecture": ["Distributed"],                          "notes": "Line Card reload. Distributed modular chassis only (e.g., ASR-9000 modular, NCS-5500 modular)." },
          { "name": "FC",     "applies_to_architecture": ["Distributed"],                          "notes": "Fabric Card reload. Distributed modular chassis only; reloads a fabric / switching-fabric card (e.g., ASR-9000 SFC, NCS-5500 modular FC)." }
        ]
