  "automation_readiness": {
    "description": "Whether enough evidence exists to write a reliable, automatable test case. Always computed from CDETS field quality × confidence. TZ cross-validation enriches when available but is NOT required.",
    "method": "field_quality_x_confidence",
    "per_field_rules": {
      "ACTIONABLE+HIGH_or_MEDIUM": "YES",
      "ACTIONABLE+LOW": "CONDITIONAL",
      "ASSERTED_NEGATIVE+HIGH_or_MEDIUM": "YES",
      "ASSERTED_NEGATIVE+LOW": "CONDITIONAL",
      "LOW_SPECIFICITY+any": "NOT_READY",
      "MISSING+any": "NOT_READY"
    },
    "tz_adjustment": "TZ CONFIRMED/ENRICHED upgrades CONDITIONAL→YES; TZ CONTRADICTED downgrades YES→NOT READY",
    "field_readiness": {},
    "fields_ready": 0,
    "fields_conditional": 0,
    "fields_not_ready": 0,
    "verdict": null,
    "verdict_thresholds": {
      "READY FOR AUTOMATION": ">75% weighted fields automation-ready",
      "AUTOMATABLE — REVIEW RECOMMENDED": "60-75% weighted fields automation-ready",
      "NOT READY FOR AUTOMATION": "<60% weighted fields automation-ready"
    }
  },
  "ai_confidence": {
    "description": "How reliably the agent extracted, interpreted, and inferred each schema field. Always computed — base from CDETS extraction method, TZ cross-validation adjusts when available. Independent of CDETS defect quality score.",
    "method": "weighted_extraction_confidence",
    "extraction_values": {
      "HIGH": 1.0,
      "MEDIUM": 0.7,
      "LOW": 0.4,
      "NONE": 0.0
    },
    "extraction_definitions": {
      "HIGH": "Structured CDETS metadata (enum, dropdown, fixed-format field)",
      "MEDIUM": "Free-text analysis of CDETS description/comments, or TZ-only source",
      "LOW": "Inferred from attachments, logs, or LLM assumption, or TZ-contradicted",
      "NONE": "Field is MISSING — no data to interpret"
    },
    "tz_adjustments": {
      "CONFIRMED": "Upgrade to HIGH (1.0)",
      "ENRICHED": "Upgrade to at least MEDIUM (0.7)",
      "CONTRADICTED": "Override to LOW (0.4)",
      "TZ_ONLY": "Set to MEDIUM (0.7)",
      "TZ_SILENT": "No change"
    },
    "formula": "sum(field_ai_confidence_value × field_weight) / sum(field_weight) × 100",
    "grade_thresholds": {
      "HIGH": ">=75%",
      "MEDIUM": "50-74%",
      "LOW": "<50%"
    },
