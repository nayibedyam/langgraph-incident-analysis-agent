    "field_quality": {
      "description": "Per-field quality assessment. Each scored field receives a quality grade that multiplies with its weight and confidence factor.",
      "quality_levels": {
        "0":    "MISSING — null / empty / UNKNOWN / empty array or object",
        "0.5":  "LOW_SPECIFICITY — present but generic (fewer than 3 meaningful tokens, no concrete values, or only boilerplate text)",
        "0.75": "ASSERTED_NEGATIVE — negation or absence value (e.g. traffic=NO, soak=NO, physical_intervention=NO) without explicit submitter rationale; cap for negative/default answers",
        "1.0":  "ACTIONABLE — present with specific, reproducible detail AND backed by a citable CDETS source (description line, comment, field value, or attachment reference)"
      },
      "field_scores": {}
    },
    "field_confidence": {
      "description": "Per-field extraction confidence. Algorithmically assigned based on data source. Directly multiplies into the score via confidence_factor.",
      "confidence_levels": {
        "HIGH":   "Populated from structured CDETS metadata (enum, dropdown, fixed-format field)",
        "MEDIUM": "Populated from free-text analysis of CDETS description, comments, or scrubber notes",
        "LOW":    "Inferred from attachment analysis (logs, CLI output, pcaps, traces) or LLM default assumption"
      },
      "confidence_factors": {
        "HIGH":   1.0,
        "MEDIUM": 0.8,
        "LOW":    0.5
      },
      "field_confidences": {}
    },
    "field_evidence": {
      "description": "Per-field citation anchor. Quality=1.0 requires a non-empty citation. If the agent cannot cite a specific CDETS source, quality is capped at 0.5 regardless of how specific the value looks.",
      "citations": {}
    },
    "cross_field_consistency": {
      "description": "Cross-field derivation signals. These are zero-penalty investigation signals — the agent derives correct values from CDETS evidence (description, comments, enclosures, logs, show commands) and feeds them into test case design. No score deductions.",
      "max_penalty_percent": 0,
      "derivation_signals": [
        {
          "id": "TRAFFIC_DERIVATION",
          "purpose": "Derive whether data-plane traffic is required from CDETS evidence",
          "fields": ["defect.repro.traffic.required", "defect.failure.category"],
          "penalty_percent": 0,
          "derivation_guide": "Read description, enclosure logs, show commands for traffic/forwarding/counter/TG references. Distinguish data-plane TG traffic from control-plane protocol traffic. Derived value feeds into test case Step F.3 traffic plan."
        },
        {
          "id": "SOAK_DERIVATION",
          "purpose": "Derive whether soak/longevity testing is required from CDETS evidence",
          "fields": ["defect.repro.reproducibility.value", "defect.repro.soak.required"],
          "penalty_percent": 0,
          "derivation_guide": "Read description for time references (after Nhrs, over days, gradual). Check enclosure logs for timestamps, memory trends, leak-rates. Failure categories Memory Leaks, CPU Hog, Performance Degradation often imply soak. Derived value feeds into test case Step F.5 duration."
        },
        {
          "id": "PHYSICAL_INTERVENTION_DERIVATION",
          "purpose": "Derive whether physical intervention (OIR, power cycle, cable pull) is required",
          "fields": ["defect.dependencies.physical_intervention.required"],
          "penalty_percent": 0,
          "derivation_guide": "Read description and repro steps for OIR, pull, power cycle, hot swap, cable disconnect. Physical actions are usually explicit. Derived value feeds into test case Step F.9 automation feasibility."
        },
        {
          "id": "SCOPE_DERIVATION",
          "purpose": "Derive whether defect is single-feature or cross-feature interaction",
          "fields": ["defect.component.feature_scope.type", "defect.ap_selection.related_aps"],
          "penalty_percent": 0,
          "derivation_guide": "Read description for multi-feature references. Check if related_aps represent genuine interaction or metadata hints. Derived value feeds into test case Step F.2 topology scope."
        },
        {
          "id": "SEVERITY_PRIORITY_OBSERVATION",
          "purpose": "Record severity and priority as-is from CDETS structured fields",
          "fields": ["defect.behavior.impact.severity", "defect.behavior.impact.priority"],
          "penalty_percent": 0,
          "derivation_guide": "Triage/business signal. Recorded as-is, no derivation needed, no test case impact."
        },
        {
          "id": "VERSION_FIXED_OBSERVATION",
          "purpose": "Record version-fixed status as-is from CDETS",
          "fields": ["meta.source_system.status", "defect.versions.fixed.release_train"],
          "penalty_percent": 0,
          "derivation_guide": "Process state field. Recorded as-is, no derivation needed, no test case impact."
        }
      ],
      "violations_found": [],
      "total_penalty_percent": 0
    },
