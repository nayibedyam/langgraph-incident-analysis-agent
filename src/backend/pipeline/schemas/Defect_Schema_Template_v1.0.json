  "tz_cross_validation": {
    "description": "Techzone cross-validation results — separate from defect_score. Techzone NEVER modifies the CDETS defect quality score. This section feeds AI Confidence and Automation Readiness only.",
    "available": false,
    "outcome_definitions": {
      "CONFIRMED": "Both CDETS and Techzone agree — AI Confidence = HIGH, automation-ready = true",
      "ENRICHED": "Techzone adds detail without contradicting CDETS — AI Confidence = HIGH, automation-ready = true",
      "CONTRADICTED": "CDETS and Techzone disagree — AI Confidence = LOW, automation-ready = false, flagged for review",
      "TZ_ONLY": "Techzone has data but CDETS field was empty — AI Confidence = MEDIUM, automation-ready = conditional",
      "TZ_SILENT": "Techzone has no relevant data for this field — no change"
    },
    "field_results": {},
