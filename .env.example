# ─── LLM gateway / Azure OpenAI (REQUIRED) ───
AZURE_OPENAI_ENDPOINT=https://your-llm-gateway.example.com
AZURE_OPENAI_API_KEY=your-access-token-here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Gateway attribution headers
GATEWAY_APP_KEY=your-app-key-here
GATEWAY_USER_ID=your-gateway-user-id

# Optional per-stage deployments (fall back to AZURE_OPENAI_DEPLOYMENT if unset)
AZURE_OPENAI_DEPLOYMENT_SCORING=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_EMAIL=gpt-4o-mini

# ─── MongoDB ───
MONGO_URI=mongodb://<user>:<password>@<host>:27017/?authSource=admin

# ─── CDETS tools ───
FL_CAFY_AP_ROOT=/path/to/cafy/work-dir
FL_BLUEPRINT_ROOT=/path/to/blueprints

# ─── Feedback tokens (optional) ───
FEEDBACK_TOKEN_SECRET=

# ─── Dashboard ───
DASHBOARD_URL=http://your-dashboard-host:3005

# ─── Email ───
SMTP_HOST=localhost
SMTP_PORT=25
EMAIL_FROM=fl-agent@example.com
